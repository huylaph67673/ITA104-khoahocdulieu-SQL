select
    od.invoice_id,
    p.ten_san_pham,
    od.so_luong,
    od.don_gia
from order_detail_2 od
inner join product_2 p 
    on od.product_id = p.product_id;


select
    c.ten_khach_hang,
    i.invoice_id
from customer_2 c
left join invoice_2 i 
    on c.customer_id = i.customer_id;
	
select 
    p.ten_san_pham,
    od.invoice_id
from order_detail_2 od
right join product_2 p
    on od.product_id = p.product_id;

