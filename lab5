-- Xóa bảng cũ nếu có
DROP TABLE IF EXISTS order_detail_2;
DROP TABLE IF EXISTS invoice_2;
DROP TABLE IF EXISTS product_2;
DROP TABLE IF EXISTS supplier_2;
DROP TABLE IF EXISTS customer_2;

-- 1. Customer
CREATE TABLE customer_2 (
    customer_id INT PRIMARY KEY,
    ten_khach_hang VARCHAR(100),
    so_dien_thoai VARCHAR(15),
    dia_chi VARCHAR(255)
);

-- 2. Supplier
CREATE TABLE supplier_2 (
    supplier_id INT PRIMARY KEY,
    supplier_name VARCHAR(100),
    so_dien_thoai VARCHAR(15)
);

-- 3. Product
CREATE TABLE product_2 (
    product_id INT PRIMARY KEY,
    ten_san_pham VARCHAR(100),
    don_gia DECIMAL(10,2),
    supplier_id INT,
    FOREIGN KEY (supplier_id) REFERENCES supplier_2(supplier_id)
);

-- 4. Invoice
CREATE TABLE invoice_2 (
    invoice_id INT PRIMARY KEY,
    ngay_tao DATE,
    tong_tien DECIMAL(10,2),
    customer_id INT,
    FOREIGN KEY (customer_id) REFERENCES customer_2(customer_id)
);

-- 5. Order Detail
CREATE TABLE order_detail_2 (
    invoice_id INT,
    product_id INT,
    so_luong INT,
    don_gia DECIMAL(10,2),
    PRIMARY KEY (invoice_id, product_id),
    FOREIGN KEY (invoice_id) REFERENCES invoice_2(invoice_id),
    FOREIGN KEY (product_id) REFERENCES product_2(product_id)
);




