select 
    ten_san_pham,
    don_gia
from product_2
where supplier_id in (
   select supplier_id
    from supplier_2
   where supplier_name = 'Vinamilk'
);


select
    ten_san_pham,
    don_gia,
    (select avg (don_gia)from product_2) as gia_trung_binh
from product_2;




select *
from (
   select
        invoice_id,
       sum(so_luong * don_gia) as tong_tien
    from order_detail_2
    group by invoice_id
) as temp
where  tong_tien > 50000;






select supplier_name
from supplier_2 s
where exists (
    select 1
    from product_2 p
    where p.supplier_id = s.supplier_id
);
